# Sentinel-X environment sample
# Copy this file to ".env" only when you need local overrides.
# MCP clients can also pass the same values in their server env config.

# Runtime root inspected by Sentinel-X.
# Default if omitted: current working directory used to launch server.js.
# Use an absolute path in MCP clients; relative roots are how config turns into a lottery.
MCP_ROOT=C:\Users\Nack\mcp01\sentinel-x

# Default database profile used when connection_name is omitted.
# Implemented values: sqlite, mssql, sqlsrv
DB_CONNECTION=sqlite
DB_DATABASE=database.sqlite

# Default MSSQL / SQL Server profile alternative.
# Uncomment this block instead of the SQLite defaults above.
# DB_CONNECTION=sqlsrv
# DB_HOST=127.0.0.1
# DB_PORT=1433
# DB_DATABASE=sentinel_db
# DB_USERNAME=sa
# DB_PASSWORD=secret
# DB_ENCRYPT=false
# DB_TRUST_SERVER_CERTIFICATE=true

# Named database profiles.
# Add a suffix to every DB_* variable, then pass that suffix as connection_name.
# Valid suffix format: letters, numbers, and single underscores only.
# Examples: LOGS, ANALYTICS, APP_LOGS

# Example: db_query with connection_name="LOGS"
# DB_CONNECTION_LOGS=sqlsrv
# DB_HOST_LOGS=10.0.0.50
# DB_PORT_LOGS=1433
# DB_DATABASE_LOGS=my_project_logs_db
# DB_USERNAME_LOGS=logger
# DB_PASSWORD_LOGS=secret_logs
# DB_ENCRYPT_LOGS=false
# DB_TRUST_SERVER_CERTIFICATE_LOGS=true

# Example: db_schema_graph with connection_name="ANALYTICS"
# DB_CONNECTION_ANALYTICS=sqlite
# DB_DATABASE_ANALYTICS=storage/analytics.sqlite

# Supported variable matrix:
# Default:   DB_CONNECTION, DB_DATABASE, DB_HOST, DB_PORT, DB_USERNAME, DB_PASSWORD, DB_ENCRYPT, DB_TRUST_SERVER_CERTIFICATE
# Named:     DB_CONNECTION_<NAME>, DB_DATABASE_<NAME>, DB_HOST_<NAME>, DB_PORT_<NAME>, DB_USERNAME_<NAME>, DB_PASSWORD_<NAME>, DB_ENCRYPT_<NAME>, DB_TRUST_SERVER_CERTIFICATE_<NAME>
# SQLite:    DB_CONNECTION + DB_DATABASE
# MSSQL:     DB_CONNECTION + DB_HOST + DB_PORT + DB_DATABASE + DB_USERNAME + DB_PASSWORD + DB_ENCRYPT + DB_TRUST_SERVER_CERTIFICATE
